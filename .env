# Composer Keys
COMPOSER_KEY_ID='Key'
COMPOSER_SECRET='Secret'

# Your Composer Account UUIDs (comma separated if you have more than one)
ACCOUNT_UUIDS='Account1,Account2,Account3'

# Alpaca Keys (Paper or Live, doesn't matter for data)
ALPACA_KEY='Key'
ALPACA_SECRET='Secret'

# Discord Webhook (Where you want your alerts to go)
DISCORD_WEBHOOK_URL='https://discord.com/api/webhooks/...'

# Sensitivity Dial: 15.0 is default. 
# Lower = more patient (waits for massive spikes). Higher = more aggressive taking profit.
TRIGGER_THRESHOLD_PCT='15.0'

# Algorithm Parameters
ATR_LOOKBACK_DAYS='14'
BASE_ATR_MULTIPLIER='2'
RED_DAY_ATR_MULTIPLIER='0.75'
MIN_MULTIPLIER_FLOOR='0.5'
LIVE_EXECUTION='True'
TRAILING_STOP_PCT='1'
BREAKEVEN_ACTIVATION_PCT='1.0'
ENDING_STOP_PCT=0.5
